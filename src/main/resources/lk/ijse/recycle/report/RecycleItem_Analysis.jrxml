<?xml version="1.0" encoding="utf-8"?>
<!DOCTYPE jasperReport PUBLIC "-//JasperReports//DTD Report Design//EN" "http://jasperreports.sourceforge.net/dtds/jasperreport.dtd">
<jasperReport name="RecycleItem_Analysis" language="java"
              pageWidth="1100" pageHeight="842" columnWidth="1060"
              leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20">

    <property name="com.jaspersoft.studio.data.defaultdataadapter" value="ecoplayer"/>

    <queryString language="SQL"><![CDATA[
SELECT r.item_id, m.material_name, r.item_kg, r.item_price, r.date
FROM recycle_item r
JOIN materials m ON r.material_id = m.material_id
ORDER BY m.material_name, r.item_id
]]></queryString>

    <field name="item_id" class="java.lang.Integer"/>
    <field name="material_name" class="java.lang.String"/>
    <field name="item_kg" class="java.lang.Double"/>
    <field name="item_price" class="java.lang.Double"/>
    <field name="date" class="java.sql.Date"/>

    <!-- Overall totals -->
    <variable name="TOTAL_KG" class="java.lang.Double" calculation="Sum">
        <variableExpression><![CDATA[$F{item_kg}]]></variableExpression>
    </variable>

    <variable name="TOTAL_PRICE" class="java.lang.Double" calculation="Sum">
        <variableExpression><![CDATA[$F{item_price}]]></variableExpression>
    </variable>

    <!-- FIXED: Proper derived average (overall) -->
    <variable name="AVG_PRICE_PER_KG" class="java.lang.Double" calculation="Nothing">
        <variableExpression><![CDATA[
            ($V{TOTAL_KG} != null && $V{TOTAL_KG}.doubleValue() != 0.0 && $V{TOTAL_PRICE} != null)
            ? new Double($V{TOTAL_PRICE}.doubleValue() / $V{TOTAL_KG}.doubleValue())
            : null
        ]]></variableExpression>
    </variable>

    <!-- Per-material totals -->
    <variable name="MAT_TOTAL_KG" class="java.lang.Double" calculation="Sum" resetType="Group" resetGroup="MaterialGroup">
        <variableExpression><![CDATA[$F{item_kg}]]></variableExpression>
    </variable>

    <variable name="MAT_TOTAL_PRICE" class="java.lang.Double" calculation="Sum" resetType="Group" resetGroup="MaterialGroup">
        <variableExpression><![CDATA[$F{item_price}]]></variableExpression>
    </variable>

    <!-- FIXED: Proper derived average per group -->
    <variable name="MAT_AVG_PRICE_PER_KG" class="java.lang.Double" calculation="Nothing" resetType="Group" resetGroup="MaterialGroup">
        <variableExpression><![CDATA[
            ($V{MAT_TOTAL_KG} != null && $V{MAT_TOTAL_KG}.doubleValue() != 0.0 && $V{MAT_TOTAL_PRICE} != null)
            ? new Double($V{MAT_TOTAL_PRICE}.doubleValue() / $V{MAT_TOTAL_KG}.doubleValue())
            : null
        ]]></variableExpression>
    </variable>

    <!-- Group by material_name -->
    <group name="MaterialGroup">
        <groupExpression><![CDATA[$F{material_name}]]></groupExpression>

        <groupHeader>
            <band height="30">
                <staticText>
                    <reportElement x="0" y="0" width="1060" height="20"/>
                    <textElement textAlignment="Left"><font size="15" isBold="true"/></textElement>
                    <text><![CDATA[Material: ]]></text>
                </staticText>
                <textField>
                    <reportElement x="100" y="0" width="300" height="20"/>
                    <textElement textAlignment="Left"><font size="15" isBold="true"/></textElement>
                    <textFieldExpression><![CDATA[$F{material_name}]]></textFieldExpression>
                </textField>
            </band>
        </groupHeader>

        <groupFooter>
            <band height="50">
                <staticText>
                    <reportElement x="20" y="0" width="300" height="20"/>
                    <textElement textAlignment="Left"><font size="12" isBold="true"/></textElement>
                    <text><![CDATA[Material Analysis:]]></text>
                </staticText>

                <textField>
                    <reportElement x="40" y="20" width="160" height="15"/>
                    <textElement textAlignment="Left"><font size="11"/></textElement>
                    <textFieldExpression><![CDATA[
                        "Total KG: " + ($V{MAT_TOTAL_KG} == null ? "0.00" : String.format("%.2f", $V{MAT_TOTAL_KG}))
                    ]]></textFieldExpression>
                </textField>

                <textField>
                    <reportElement x="200" y="20" width="200" height="15"/>
                    <textElement textAlignment="Left"><font size="11"/></textElement>
                    <textFieldExpression><![CDATA[
                        "Total Price: Rs. " + ($V{MAT_TOTAL_PRICE} == null ? "0.00" : String.format("%.2f", $V{MAT_TOTAL_PRICE}))
                    ]]></textFieldExpression>
                </textField>

                <!-- FIXED: Always returns String, never mixed types -->
                <textField>
                    <reportElement x="400" y="20" width="400" height="15"/>
                    <textElement textAlignment="Left"><font size="11"/></textElement>
                    <textFieldExpression><![CDATA[
                        "Avg Price per KG: Rs. " +
                        ($V{MAT_AVG_PRICE_PER_KG} == null ? "N/A" : String.format("%.2f", $V{MAT_AVG_PRICE_PER_KG}))
                    ]]></textFieldExpression>
                </textField>
            </band>
        </groupFooter>
    </group>

    <title>
        <band height="60">
            <staticText>
                <reportElement x="0" y="10" width="1060" height="40"/>
                <textElement textAlignment="Center">
                    <font size="28" isBold="true"/>
                </textElement>
                <text><![CDATA[RECYCLE ITEM ADVANCED ANALYSIS]]></text>
            </staticText>
        </band>
    </title>

    <columnHeader>
        <band height="35">
            <staticText>
                <reportElement x="0" y="5" width="80" height="25"/>
                <textElement textAlignment="Center"><font size="13" isBold="true"/></textElement>
                <text><![CDATA[Item ID]]></text>
            </staticText>

            <staticText>
                <reportElement x="90" y="5" width="200" height="25"/>
                <textElement textAlignment="Center"><font size="13" isBold="true"/></textElement>
                <text><![CDATA[Material Name]]></text>
            </staticText>

            <staticText>
                <reportElement x="300" y="5" width="120" height="25"/>
                <textElement textAlignment="Center"><font size="13" isBold="true"/></textElement>
                <text><![CDATA[Item KG]]></text>
            </staticText>

            <staticText>
                <reportElement x="430" y="5" width="120" height="25"/>
                <textElement textAlignment="Center"><font size="13" isBold="true"/></textElement>
                <text><![CDATA[Item Price]]></text>
            </staticText>

            <staticText>
                <reportElement x="560" y="5" width="220" height="25"/>
                <textElement textAlignment="Center"><font size="13" isBold="true"/></textElement>
                <text><![CDATA[Date]]></text>
            </staticText>
        </band>
    </columnHeader>

    <!-- No detail band: only show material summary, not individual items -->

    <summary>
        <band height="100">
            <staticText>
                <reportElement x="0" y="0" width="1060" height="20"/>
                <textElement textAlignment="Left"><font size="14" isBold="true"/></textElement>
                <text><![CDATA[Advanced Recycle Item Analysis]]></text>
            </staticText>

            <textField>
                <reportElement x="0" y="25" width="400" height="20"/>
                <textElement textAlignment="Left"><font size="12"/></textElement>
                <textFieldExpression><![CDATA[
                    "Total KG: " + ($V{TOTAL_KG} == null ? "0.00" : String.format("%.2f", $V{TOTAL_KG}))
                ]]></textFieldExpression>
            </textField>

            <textField>
                <reportElement x="0" y="50" width="400" height="20"/>
                <textElement textAlignment="Left"><font size="12"/></textElement>
                <textFieldExpression><![CDATA[
                    "Total Price: Rs. " + ($V{TOTAL_PRICE} == null ? "0.00" : String.format("%.2f", $V{TOTAL_PRICE}))
                ]]></textFieldExpression>
            </textField>

            <!-- FIXED: Never prints null -->
            <textField>
                <reportElement x="0" y="75" width="600" height="20"/>
                <textElement textAlignment="Left"><font size="12"/></textElement>
                <textFieldExpression><![CDATA[
                    "Average Price per KG: Rs. " +
                    ($V{AVG_PRICE_PER_KG} == null ? "N/A" : String.format("%.2f", $V{AVG_PRICE_PER_KG}))
                ]]></textFieldExpression>
            </textField>
        </band>
    </summary>

</jasperReport>
