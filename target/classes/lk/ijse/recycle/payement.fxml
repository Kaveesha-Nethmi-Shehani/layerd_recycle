<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<AnchorPane prefHeight="600.0" prefWidth="750.0" style="-fx-background-color: #013220;" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="lk.ijse.recycle.controller.PaymentController">
   <children>
      <!-- Title -->
      <Label layoutX="250.0" layoutY="10.0" text="PAYMENT MANAGEMENT" textFill="white">
         <font>
            <Font name="System Bold Italic" size="18.0" />
         </font>
      </Label>
      
      <!-- Form Fields - Left Side -->
      <Label layoutX="20.0" layoutY="45.0" text="Payment ID" textFill="white">
         <font><Font name="System Bold" size="12.0" /></font>
      </Label>
      <Label fx:id="lblPayment_Id" layoutX="20.0" layoutY="63.0" prefHeight="25.0" prefWidth="280.0" style="-fx-background-color: #1a4a1a; -fx-background-radius: 5; -fx-padding: 5;" text="N/A" textFill="#7CFC00">
         <font><Font name="System Bold" size="14.0" /></font>
      </Label>
      
      <Label layoutX="29.0" layoutY="99.0" text="Order ID" textFill="white">
         <font><Font name="System Bold" size="12.0" /></font>
      </Label>
      <TextField fx:id="txtOrder_Id" layoutX="20.0" layoutY="125.0" prefWidth="280.0" promptText="Enter Order ID" style="-fx-background-radius: 5;" />
      
      <Label layoutX="29.0" layoutY="166.0" text="Invoice" textFill="white">
         <font><Font name="System Bold" size="12.0" /></font>
      </Label>
      <TextField fx:id="txtInvoice" layoutX="20.0" layoutY="190.0" prefWidth="280.0" promptText="Enter Invoice Number" style="-fx-background-radius: 5;" />
      
      <Label layoutX="20.0" layoutY="229.0" text="Payment Value" textFill="white">
         <font><Font name="System Bold" size="12.0" /></font>
      </Label>
      <TextField fx:id="txtPayment_Value" layoutX="20.0" layoutY="255.0" prefWidth="280.0" promptText="Enter Payment Value" style="-fx-background-radius: 5;" />
      
      <!-- Buttons - Right Side -->
      <Button layoutX="340.0" layoutY="63.0" mnemonicParsing="false" onAction="#btnSaveOnAction" prefHeight="30.0" prefWidth="85.0" style="-fx-background-color: #0E5930;" text="Save" textFill="white">
         <font><Font name="System Bold" size="11.0" /></font>
      </Button>
      <Button layoutX="440.0" layoutY="63.0" mnemonicParsing="false" onAction="#btnUpdateOnAction" prefHeight="30.0" prefWidth="85.0" style="-fx-background-color: #639354;" text="Update" textFill="white">
         <font><Font name="System Bold" size="11.0" /></font>
      </Button>
      <Button layoutX="540.0" layoutY="63.0" mnemonicParsing="false" onAction="#btnDeleteOnAction" prefHeight="30.0" prefWidth="85.0" style="-fx-background-color: #7CFC00;" text="Delete">
         <font><Font name="System Bold" size="11.0" /></font>
      </Button>
      <Button layoutX="340.0" layoutY="108.0" mnemonicParsing="false" onAction="#btnResetOnAction" prefHeight="30.0" prefWidth="85.0" style="-fx-background-color: #356C08;" text="Reset" textFill="white">
         <font><Font name="System Bold" size="11.0" /></font>
      </Button>
      <Button layoutX="440.0" layoutY="108.0" mnemonicParsing="false" onAction="#btnSearchOnAction" prefHeight="30.0" prefWidth="85.0" style="-fx-background-color: #2E5B0C;" text="Search" textFill="white">
         <font><Font name="System Bold" size="11.0" /></font>
      </Button>
      
      <!-- Table - Bottom -->
      <TableView fx:id="tblPayment" layoutX="20.0" layoutY="295.0" prefHeight="290.0" prefWidth="710.0">
         <columns>
            <TableColumn fx:id="colPayment_Id" prefWidth="150.9999942779541" text="Payment ID" />
            <TableColumn fx:id="colOrder_Id" prefWidth="132.19998168945312" text="Order ID" />
            <TableColumn fx:id="colInvoice" prefWidth="165.00003051757812" text="Invoice" />
            <TableColumn fx:id="colPayment_Value" prefWidth="262.2000427246094" text="Payment Value" />
         </columns>
      </TableView>
   </children>
</AnchorPane>
