<?xml version="1.0" encoding="utf-8"?>
<!DOCTYPE jasperReport PUBLIC "-//JasperReports//DTD Report Design//EN" "http://jasperreports.sourceforge.net/dtds/jasperreport.dtd">
<jasperReport name="Product_report" language="java" pageWidth="595" pageHeight="842" columnWidth="555" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20">
	<property name="com.jaspersoft.studio.data.defaultdataadapter" value="ecoplayer"/>
	<queryString language="SQL"><![CDATA[
SELECT p.product_id, p.product_name, m.material_name AS product_materials
FROM product p
LEFT JOIN materials m ON p.material_id = m.material_id
]]></queryString>
	<field name="product_id" class="java.lang.String"/>
	<field name="product_name" class="java.lang.String"/>
	<field name="product_materials" class="java.lang.String"/>
	<title>
		<band height="50">
			<staticText>
				<reportElement x="180" y="10" width="200" height="30"/>
				<textElement textAlignment="Center">
					<font size="22" isBold="true"/>
				</textElement>
				<text><![CDATA[PRODUCT REPORT]]></text>
			</staticText>
		</band>
	</title>
	<pageHeader>
		<band height="40">
			<staticText>
				<reportElement x="200" y="5" width="160" height="30" forecolor="#195E1C"/>
				<textElement textAlignment="Center">
					<font size="18" isBold="true" isItalic="true"/>
				</textElement>
				<text><![CDATA[ECOPLAYER]]></text>
			</staticText>
		</band>
	</pageHeader>
	<columnHeader>
		<band height="40">
			<staticText>
				<reportElement x="0" y="10" width="150" height="25"/>
				<textElement><font size="12" isBold="true"/></textElement>
				<text><![CDATA[Product ID]]></text>
			</staticText>
			<staticText>
				<reportElement x="180" y="10" width="180" height="25"/>
				<textElement><font size="12" isBold="true"/></textElement>
				<text><![CDATA[Product Name]]></text>
			</staticText>
			<staticText>
				<reportElement x="380" y="10" width="170" height="25"/>
				<textElement><font size="12" isBold="true"/></textElement>
				<text><![CDATA[Product Materials]]></text>
			</staticText>
		</band>
	</columnHeader>
	<detail>
		<band height="30">
			<textField>
				<reportElement x="0" y="5" width="150" height="20"/>
				<textElement><font size="11"/></textElement>
				<textFieldExpression><![CDATA[$F{product_id}]]></textFieldExpression>
			</textField>
			<textField>
				<reportElement x="180" y="5" width="180" height="20"/>
				<textElement><font size="11"/></textElement>
				<textFieldExpression><![CDATA[$F{product_name}]]></textFieldExpression>
			</textField>
			<textField>
				<reportElement x="380" y="5" width="170" height="20"/>
				<textElement><font size="11"/></textElement>
				<textFieldExpression><![CDATA[$F{product_materials}]]></textFieldExpression>
			</textField>
		</band>
	</detail>
	<pageFooter>
		<band height="50">
			<staticText>
				<reportElement x="0" y="10" width="555" height="30" forecolor="#1C3623"/>
				<textElement textAlignment="Center">
					<font size="14" isBold="true" isItalic="true"/>
				</textElement>
				<text><![CDATA[RECYCLE FOR A GREEN TOMORROW]]></text>
			</staticText>
		</band>
	</pageFooter>
</jasperReport>
