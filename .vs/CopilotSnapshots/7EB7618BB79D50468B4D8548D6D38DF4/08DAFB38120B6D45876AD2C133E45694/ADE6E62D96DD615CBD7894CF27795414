package lk.ijse.recycle.dto;

public class OrderDto {
    private int orderId;
    private String bileId;
    private String productName;
    private int customerId;

    public OrderDto() {}

    public OrderDto(int orderId, String bileId, String productName, int customerId) {
        this.orderId = orderId;
        this.bileId = bileId;
        this.productName = productName;
        this.customerId = customerId;
    }

    public int getOrderId() { return orderId; }
    public String getBileId() { return bileId; }
    public String getProductName() { return productName; }
    public int getCustomerId() { return customerId; }

    public void setOrderId(int orderId) { this.orderId = orderId; }
    public void setBileId(String bileId) { this.bileId = bileId; }
    public void setProductName(String productName) { this.productName = productName; }
    public void setCustomerId(int customerId) { this.customerId = customerId; }

    @Override
    public String toString() {
        return "OrderDto{" +
                "orderId=" + orderId +
                ", bileId='" + bileId + '\'' +
                ", productName='" + productName + '\'' +
                ", customerId=" + customerId +
                '}';
    }
}


