<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<AnchorPane prefHeight="600.0" prefWidth="750.0" style="-fx-background-color: #013220;" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="lk.ijse.recycle.controller.RecycleItemController">
   <children>
      <!-- Title -->
      <Label layoutX="220.0" layoutY="10.0" text="RECYCLE ITEMS MANAGEMENT" textFill="white">
         <font>
            <Font name="System Bold Italic" size="18.0" />
         </font>
      </Label>
      
      <!-- Form Fields - Left Side -->
      <Label layoutX="20.0" layoutY="45.0" text="Item ID" textFill="white">
         <font><Font name="System Bold" size="12.0" /></font>
      </Label>
      <Label fx:id="lblItem_Id" layoutX="20.0" layoutY="63.0" prefWidth="280.0" prefHeight="25.0" text="N/A" textFill="#7CFC00" style="-fx-background-color: #1a4a1a; -fx-background-radius: 5; -fx-padding: 5;">
         <font><Font name="System Bold" size="14.0" /></font>
      </Label>
      
      <Label layoutX="20.0" layoutY="98.0" text="Item Materials" textFill="white">
         <font><Font name="System Bold" size="12.0" /></font>
      </Label>
      <TextField fx:id="txtItem_Materials" layoutX="20.0" layoutY="116.0" prefWidth="280.0" promptText="Enter Item Materials" style="-fx-background-radius: 5;" />
      
      <Label layoutX="20.0" layoutY="151.0" text="Item Weight (KG)" textFill="white">
         <font><Font name="System Bold" size="12.0" /></font>
      </Label>
      <TextField fx:id="txtItem_Kg" layoutX="20.0" layoutY="169.0" prefWidth="280.0" promptText="Enter Weight in KG" style="-fx-background-radius: 5;" />
      
      <Label layoutX="20.0" layoutY="204.0" text="Rate Applied" textFill="white">
         <font><Font name="System Bold" size="12.0" /></font>
      </Label>
      <Label fx:id="lblPrice_Per_Kg" layoutX="20.0" layoutY="222.0" prefWidth="280.0" prefHeight="25.0" text="Enter weight" textFill="#FFD700" style="-fx-background-color: #1a4a1a; -fx-background-radius: 5; -fx-padding: 5;">
         <font><Font name="System Bold" size="12.0" /></font>
      </Label>
      
      <Label layoutX="20.0" layoutY="257.0" text="Total Price (LKR) - Auto Calculated" textFill="white">
         <font><Font name="System Bold" size="12.0" /></font>
      </Label>
      <Label fx:id="lblItem_Price" layoutX="20.0" layoutY="275.0" prefWidth="280.0" prefHeight="30.0" text="LKR 0.00" textFill="#00FF00" style="-fx-background-color: #1a4a1a; -fx-background-radius: 5; -fx-padding: 5;">
         <font><Font name="System Bold" size="16.0" /></font>
      </Label>
      
      <Label layoutX="20.0" layoutY="315.0" text="Item Date" textFill="white">
         <font><Font name="System Bold" size="12.0" /></font>
      </Label>
      <DatePicker fx:id="txtItem_Date" layoutX="20.0" layoutY="333.0" prefWidth="280.0" />
      
      <!-- Buttons - Right Side -->
      <Button layoutX="340.0" layoutY="63.0" mnemonicParsing="false" onAction="#btnSaveOnAction" prefHeight="30.0" prefWidth="85.0" style="-fx-background-color: #2E5B0C;" text="Save" textFill="white">
         <font><Font name="System Bold" size="11.0" /></font>
      </Button>
      <Button layoutX="440.0" layoutY="63.0" mnemonicParsing="false" onAction="#btnUpdateOnAction" prefHeight="30.0" prefWidth="85.0" style="-fx-background-color: #639354;" text="Update" textFill="white">
         <font><Font name="System Bold" size="11.0" /></font>
      </Button>
      <Button layoutX="540.0" layoutY="63.0" mnemonicParsing="false" onAction="#btnDeleteOnAction" prefHeight="30.0" prefWidth="85.0" style="-fx-background-color: #7CFC00;" text="Delete">
         <font><Font name="System Bold" size="11.0" /></font>
      </Button>
      <Button layoutX="340.0" layoutY="108.0" mnemonicParsing="false" onAction="#btnResetOnAction" prefHeight="30.0" prefWidth="85.0" style="-fx-background-color: #356C08;" text="Reset" textFill="white">
         <font><Font name="System Bold" size="11.0" /></font>
      </Button>
      <Button layoutX="440.0" layoutY="108.0" mnemonicParsing="false" onAction="#btnSearchOnAction" prefHeight="30.0" prefWidth="85.0" style="-fx-background-color: #0E5930;" text="Search" textFill="white">
         <font><Font name="System Bold" size="11.0" /></font>
      </Button>
      
      <!-- Price Rate Info Panel -->
      <Label layoutX="340.0" layoutY="160.0" text="PRICING RATES (LKR per KG)" textFill="#FFD700">
         <font><Font name="System Bold" size="14.0" /></font>
      </Label>
      
      <Label layoutX="340.0" layoutY="190.0" text="Weight Range" textFill="white">
         <font><Font name="System Bold" size="11.0" /></font>
      </Label>
      <Label layoutX="500.0" layoutY="190.0" text="Rate/KG" textFill="white">
         <font><Font name="System Bold" size="11.0" /></font>
      </Label>
      
      <Label layoutX="340.0" layoutY="210.0" text="0 - 10 kg" textFill="#7CFC00">
         <font><Font size="11.0" /></font>
      </Label>
      <Label layoutX="500.0" layoutY="210.0" text="LKR 100.00" textFill="#7CFC00">
         <font><Font name="System Bold" size="11.0" /></font>
      </Label>
      
      <Label layoutX="340.0" layoutY="230.0" text="10 - 50 kg" textFill="#90EE90">
         <font><Font size="11.0" /></font>
      </Label>
      <Label layoutX="500.0" layoutY="230.0" text="LKR 80.00" textFill="#90EE90">
         <font><Font name="System Bold" size="11.0" /></font>
      </Label>
      
      <Label layoutX="340.0" layoutY="250.0" text="50 - 100 kg" textFill="#98FB98">
         <font><Font size="11.0" /></font>
      </Label>
      <Label layoutX="500.0" layoutY="250.0" text="LKR 60.00" textFill="#98FB98">
         <font><Font name="System Bold" size="11.0" /></font>
      </Label>
      
      <Label layoutX="340.0" layoutY="270.0" text="100+ kg" textFill="#ADFF2F">
         <font><Font size="11.0" /></font>
      </Label>
      <Label layoutX="500.0" layoutY="270.0" text="LKR 50.00" textFill="#ADFF2F">
         <font><Font name="System Bold" size="11.0" /></font>
      </Label>
      
      <Label layoutX="340.0" layoutY="300.0" text="* Higher weight = Lower rate per KG" textFill="#FFD700">
         <font><Font name="System Bold Italic" size="10.0" /></font>
      </Label>
      
      <!-- Table - Bottom -->
      <TableView fx:id="tblRecycleItem" layoutX="20.0" layoutY="375.0" prefHeight="210.0" prefWidth="710.0">
        <columns>
          <TableColumn fx:id="colItem_Id" prefWidth="80.0" text="Item ID" />
          <TableColumn fx:id="colItem_Materials" prefWidth="150.0" text="Materials" />
          <TableColumn fx:id="colItem_Kg" prefWidth="100.0" text="Weight (KG)" />
          <TableColumn fx:id="colItem_Price" prefWidth="150.0" text="Price (LKR)" />
          <TableColumn fx:id="colItem_Date" prefWidth="230.0" text="Date" />
        </columns>
      </TableView>
   </children>
</AnchorPane>
