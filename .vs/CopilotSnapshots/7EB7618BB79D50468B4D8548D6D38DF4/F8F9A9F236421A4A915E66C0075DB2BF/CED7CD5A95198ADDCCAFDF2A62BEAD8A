<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<AnchorPane prefHeight="600.0" prefWidth="800.0" style="-fx-background-color: #013220;" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="lk.ijse.recycle.controller.RecycleItemController">
   <children>
      <!-- Title -->
      <Label layoutX="250.0" layoutY="15.0" text="RECYCLE ITEMS MANAGEMENT" textFill="white">
         <font>
            <Font name="System Bold Italic" size="20.0" />
         </font>
      </Label>
      
      <!-- Form Fields - Left Side -->
      <Label layoutX="30.0" layoutY="55.0" text="Item ID" textFill="white">
         <font><Font name="System Bold" size="13.0" /></font>
      </Label>
      <TextField fx:id="txtItem_Id" layoutX="30.0" layoutY="75.0" prefWidth="300.0" editable="false" promptText="Auto Generated" style="-fx-background-radius: 5;" />
      
      <Label layoutX="30.0" layoutY="110.0" text="Item Materials" textFill="white">
         <font><Font name="System Bold" size="13.0" /></font>
      </Label>
      <TextField fx:id="txtItem_Materials" layoutX="30.0" layoutY="130.0" prefWidth="300.0" promptText="Enter Item Materials" style="-fx-background-radius: 5;" />
      
      <Label layoutX="30.0" layoutY="165.0" text="Item KG" textFill="white">
         <font><Font name="System Bold" size="13.0" /></font>
      </Label>
      <TextField fx:id="txtItem_Kg" layoutX="30.0" layoutY="185.0" prefWidth="300.0" promptText="Enter Weight in KG" style="-fx-background-radius: 5;" />
      
      <Label layoutX="30.0" layoutY="220.0" text="Item Price" textFill="white">
         <font><Font name="System Bold" size="13.0" /></font>
      </Label>
      <TextField fx:id="txtItem_Price" layoutX="30.0" layoutY="240.0" prefWidth="300.0" promptText="Enter Price" style="-fx-background-radius: 5;" />
      
      <Label layoutX="30.0" layoutY="275.0" text="Item Date" textFill="white">
         <font><Font name="System Bold" size="13.0" /></font>
      </Label>
      <DatePicker fx:id="txtItem_Date" layoutX="30.0" layoutY="295.0" prefWidth="300.0" />
      
      <!-- Buttons - Right Side -->
      <Button layoutX="380.0" layoutY="75.0" mnemonicParsing="false" onAction="#btnSaveOnAction" prefHeight="35.0" prefWidth="90.0" style="-fx-background-color: #2E5B0C;" text="Save" textFill="white">
         <font><Font name="System Bold" size="12.0" /></font>
      </Button>
      <Button layoutX="490.0" layoutY="75.0" mnemonicParsing="false" onAction="#btnUpdateOnAction" prefHeight="35.0" prefWidth="90.0" style="-fx-background-color: #639354;" text="Update" textFill="white">
         <font><Font name="System Bold" size="12.0" /></font>
      </Button>
      <Button layoutX="600.0" layoutY="75.0" mnemonicParsing="false" onAction="#btnDeleteOnAction" prefHeight="35.0" prefWidth="90.0" style="-fx-background-color: #7CFC00;" text="Delete">
         <font><Font name="System Bold" size="12.0" /></font>
      </Button>
      <Button layoutX="380.0" layoutY="125.0" mnemonicParsing="false" onAction="#btnResetOnAction" prefHeight="35.0" prefWidth="90.0" style="-fx-background-color: #356C08;" text="Reset" textFill="white">
         <font><Font name="System Bold" size="12.0" /></font>
      </Button>
      <Button layoutX="490.0" layoutY="125.0" mnemonicParsing="false" onAction="#btnSearchOnAction" prefHeight="35.0" prefWidth="90.0" style="-fx-background-color: #0E5930;" text="Search" textFill="white">
         <font><Font name="System Bold" size="12.0" /></font>
      </Button>
      <Button layoutX="600.0" layoutY="125.0" mnemonicParsing="false" prefHeight="35.0" prefWidth="90.0" style="-fx-background-color: #2E5B0C;" text="Report" textFill="white">
         <font><Font name="System Bold" size="12.0" /></font>
      </Button>
      
      <!-- Table - Bottom -->
      <TableView fx:id="tblRecycleItem" layoutX="30.0" layoutY="340.0" prefHeight="240.0" prefWidth="740.0">
        <columns>
          <TableColumn fx:id="colItem_Id" prefWidth="120.0" text="Item ID" />
          <TableColumn fx:id="colItem_Materials" prefWidth="180.0" text="Item Materials" />
          <TableColumn fx:id="colItem_Kg" prefWidth="120.0" text="Item KG" />
          <TableColumn fx:id="colItem_Price" prefWidth="140.0" text="Item Price" />
          <TableColumn fx:id="colItem_Date" prefWidth="180.0" text="Date" />
        </columns>
      </TableView>
   </children>
</AnchorPane>
