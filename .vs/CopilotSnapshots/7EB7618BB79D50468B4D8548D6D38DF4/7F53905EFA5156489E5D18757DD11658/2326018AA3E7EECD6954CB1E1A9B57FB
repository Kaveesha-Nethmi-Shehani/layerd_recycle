package lk.ijse.recycle.model;

import lk.ijse.recycle.db.DBConnection;
import lk.ijse.recycle.dto.ProductDto;

import java.sql.*;
import java.util.ArrayList;
import java.util.List;
import java.sql.Connection;
import java.sql.PreparedStatement;
import java.sql.ResultSet;



public class ProductModel {

    public boolean save(ProductDto dto) throws SQLException {
        String sql = "INSERT INTO product VALUES (?, ?, ?)";

        PreparedStatement stm = DBConnection.getInstance().getConnection().prepareStatement(sql);
        stm.setString(1, dto.getPro_name());
        stm.setString(2, dto.getPro_id());
        stm.setString(3, dto.getPro_materials());

        return stm.executeUpdate() > 0;
    }

        //Product and RecycleItem Transaction
        public boolean developProductFromRecycle (int recycleItemId, double usedKg, int productId, int qtyProduced) throws SQLException {
            Connection conn = DBConnection.getInstance().getConnection();

            try {
                //start the Transaction
                conn.setAutoCommit(false);

                //Recycle item eke bara(kg) adu kereme code eka
                String sql1 = "UPDATE recycle_item SET item_kg = item_kg - ? WHERE item_id=?";
                PreparedStatement pstm1 = conn.prepareStatement(sql1);
                pstm1.setDouble(1, usedKg);
                pstm1.setInt(2, recycleItemId);
                boolean isRecycleSave = pstm1.executeUpdate() > 0;

                //Product eke stock eka wade krnna
                String sql2 = "UPDATE  product SET qty = qty + ? WHERE item_id=? ";
                PreparedStatement pstm2 = conn.prepareStatement(sql2);
                pstm2.setInt(1, qtyProduced);
                pstm2.setInt(2, productId);
                boolean isRecycleSave2 = pstm2.executeUpdate() > 0;

                // dekama harenm save
                if(isRecycleSave && isRecycleSave2) {
                    conn.commit();
                  return true;
                }else{
                    conn.rollback();
                   return false;
                }

            } catch (SQLException e) {
                conn.rollback();
                throw e;
            } finally {
                conn.setAutoCommit(true);
            }

        }

        public boolean update(ProductDto dto) throws SQLException {
            String sql = "UPDATE product SET Pro_materials =?, Pro_name =?,  WHERE Pro_id=?";

            PreparedStatement stm = DBConnection.getInstance().getConnection().prepareStatement(sql);
            stm.setString(1, dto.getPro_name());
            stm.setString(2, dto.getPro_id());
            stm.setString(3, dto.getPro_materials());


            return stm.executeUpdate() > 0;
        }
        // update transaction
        public boolean updateProductId(String oldId, String newId) throws SQLException {
        Connection conn = DBConnection.getInstance().getConnection();
        try {
            conn.setAutoCommit(false);

            //Recycle TableId change the new Id
            String sql1 = "UPDATE recycle_item SET Pro_id=? WHERE Pro_id=?";
            PreparedStatement pstm1 = conn.prepareStatement(sql1);
            pstm1.setString(1, newId);
            pstm1.setString(2, oldId);
            pstm1.executeUpdate();

            //Change the Product Table ID
            String sql2 = "UPDATE product SET Pro_id=? WHERE Pro_id=?";
            PreparedStatement pstm2 = conn.prepareStatement(sql2);
            pstm2.setString(1, newId);
            pstm2.setString(2, oldId);
            boolean isProductUpdate = pstm2.executeUpdate() > 0;

            if(isProductUpdate ) {
                conn.commit();
                return true;
            }else {
                conn.rollback();
                return false;
            }
        }catch(SQLException e){
            conn.rollback();
            throw e;
        }finally {
            conn.setAutoCommit(true);
        }

    }

    public boolean delete(String id) throws SQLException {
        String sql = "DELETE FROM product WHERE Pro_id=?";

        PreparedStatement stm = DBConnection.getInstance().getConnection().prepareStatement(sql);
        stm.setString(1, id);

        return stm.executeUpdate() > 0;
    }
    // Delete Transaction
    public boolean deleteProductAndRecycleDta(String ProductId) throws SQLException {
        Connection conn = DBConnection.getInstance().getConnection();

        try {
            conn.setAutoCommit(false);

            //RecycleTable eke ema Product ekat adalwa data delete kerema
            String sql1 = "DELETE FROM recycle_item WHERE Pro_id=?";
            PreparedStatement pstm1 = conn.prepareStatement(sql1);
            pstm1.setString(1, ProductId);
            pstm1.executeUpdate();


            //Delete the ProductTable
            String sql2 = "DELETE FROM product WHERE Pro_id=?";
            PreparedStatement pstm2 = conn.prepareStatement(sql2);
            pstm2.setString(1, ProductId);
            boolean isProductDelete = pstm2.executeUpdate() > 0;

            if(isProductDelete) {
                conn.commit();
                return true;
            }else {
                conn.rollback();
                return false;
            }
        } catch (SQLException e) {
            conn.rollback();
            throw e;
        } finally {
            conn.setAutoCommit(true);
        }
    }

            public List<ProductDto> getAllProduct() throws SQLException {
                String sql = "SELECT * FROM product";

                PreparedStatement stm = DBConnection.getInstance().getConnection().prepareStatement(sql);
                ResultSet rs = stm.executeQuery();

                List<ProductDto> list = new ArrayList<>();

                while (rs.next()) {
                    list.add(new ProductDto(
                            rs.getString(1),
                            rs.getString(2),
                            rs.getString(3)

                    ));
                }
                return list;
            }
        }


