package lk.ijse.recycle.controller;

import javafx.collections.FXCollections;
import javafx.collections.ObservableList;
import javafx.event.ActionEvent;
import javafx.fxml.FXML;
import javafx.fxml.Initializable;
import javafx.scene.control.*;
import javafx.scene.control.cell.PropertyValueFactory;
import lk.ijse.recycle.dto.CustomerDto;
import lk.ijse.recycle.dto.OrderDto;
import lk.ijse.recycle.dto.PaymentDto;
import lk.ijse.recycle.model.OrderModel;
import lk.ijse.recycle.model.PaymentModel;

import java.net.URL;
import java.sql.SQLException;
import java.time.LocalDate;
import java.util.List;
import java.util.ResourceBundle;


public class OrderController implements Initializable {

    //@FXML public TextField idField;
    @FXML private TextField txtOrder_Id;
    @FXML private TextField txtCus_Id;
    @FXML private TextField txtPro_Id;
    @FXML private DatePicker txtReq_Date;

    @FXML private TableView<OrderDto> tblOrder;

    @FXML private TableColumn<OrderDto, Integer> colOrder_Id;
    @FXML private TableColumn<OrderDto, Integer> colCus_Id;
    @FXML private TableColumn<OrderDto, Integer> colPro_Id;
    @FXML private TableColumn<OrderDto, String> colReq_Date;

    private final String ORDER_ID_REGEX = "^[0-9]+$";
    private final String PRO_ID_REGEX = "^[0-9]+$";
    private final String REQ_DATE_REGEX = "^^[0-9]+$";
    private final String CUS_ID_REGEX = "^[0-9]+$";

    private final OrderModel orderModel = new OrderModel();

    @Override
    public void initialize(URL url, ResourceBundle resourceBundle) {
        setCellValueFactory();
        loadAllOrders();
    }

    private void setCellValueFactory() {
        if (colOrder_Id == null || colCus_Id == null || colPro_Id == null || colReq_Date == null) {
            return;
        }
        colOrder_Id.setCellValueFactory(new PropertyValueFactory<>("orderId"));
        colCus_Id.setCellValueFactory(new PropertyValueFactory<>("cusId"));
        colPro_Id.setCellValueFactory(new PropertyValueFactory<>("proId"));
        colReq_Date.setCellValueFactory(new PropertyValueFactory<>("reqDate"));
    }

    private void loadAllOrders() {
        if (tblOrder == null) {
            return;
        }

        try {
            tblOrder.setItems(FXCollections.observableArrayList(orderModel.getAllOrders()));
        } catch (SQLException e) {
            e.printStackTrace();
            new Alert(Alert.AlertType.ERROR, "Failed to load orders: " + e.getMessage()).show();
        }
    }

    @FXML
    public void btnSaveOnAction(ActionEvent event) {
        int order_Id = Integer.parseInt(txtOrder_Id.getText());
        String cus_Id= txtCus_Id.getText();
        int  pro_Id = Integer.parseInt(txtPro_Id .getText());
        LocalDate req_Date = txtReq_Date.getValue();

        OrderDto dto = new OrderDto(order_Id, cus_Id, pro_Id, req_Date);

        try {
            boolean saved = orderModel.saveOrders(dto);
            if (saved) {
                new Alert(Alert.AlertType.INFORMATION, "Order Saved!").show();
                loadAllOrders();
                clearFields();
            } else {
                new Alert(Alert.AlertType.ERROR, "Save Failed!").show();
            }
        } catch (SQLException e) {
            new Alert(Alert.AlertType.ERROR, e.getMessage()).show();
        }
    }
    public DatePicker getTxtReq_Date() {
        return txtReq_Date;
    }

    @FXML
    public void btnUpdateOnAction(ActionEvent event) {

        int order_Id = Integer.parseInt(txtOrder_Id.getText());
        LocalDate req_Date = txtReq_Date.getValue();
        int  pro_Id = Integer.parseInt(txtPro_Id .getText());
        String cus_Id= txtCus_Id.getText();


        OrderDto dto = new OrderDto((order_Id), (cus_Id) , (pro_Id), req_Date);

        try {
            boolean updated = orderModel.updateOrders(dto);
            if (updated) {
                new Alert(Alert.AlertType.INFORMATION, "Order Updated!").show();
                loadAllOrders();
                clearFields();
            } else {
                new Alert(Alert.AlertType.ERROR, "Update Failed!").show();
            }
        } catch (SQLException e) {
                    new Alert(Alert.AlertType.ERROR, e.getMessage()).show();
        }
    }

    @FXML
    public void btnDeleteOnAction(ActionEvent event) {

        int order_Id = Integer.parseInt(txtOrder_Id.getText());

        try {
            boolean deleted = orderModel.deleteOrders(order_Id);
            if (deleted) {
                new Alert(Alert.AlertType.INFORMATION, "Order Deleted!").show();
                loadAllOrders();
                clearFields();
            } else {
                new Alert(Alert.AlertType.ERROR, "Delete Failed!").show();
            }
        } catch (SQLException e) {
            new Alert(Alert.AlertType.ERROR, e.getMessage()).show();
        }
    }

    @FXML
    public void btnResetOnAction(ActionEvent event) {
                clearFields();
            }
            private void clearFields() {
                if(txtOrder_Id != null) txtOrder_Id.clear();
                if(txtCus_Id != null) txtCus_Id.clear();
                if(txtPro_Id!= null)txtPro_Id.clear();
                if(txtReq_Date!= null)txtReq_Date.setValue(null);
            }
            public void btnOrderIdField(ActionEvent actionEvent) {
                btnUpdateOnAction(actionEvent);
            }
              //UI eke bile Field ekak naa meka ain kramath error rkak enwa


            public void btnProductField(ActionEvent actionEvent) {
                btnDeleteOnAction(actionEvent);
            }

            public void btnIdField(ActionEvent actionEvent) {
                btnResetOnAction(actionEvent);

            }
        }


