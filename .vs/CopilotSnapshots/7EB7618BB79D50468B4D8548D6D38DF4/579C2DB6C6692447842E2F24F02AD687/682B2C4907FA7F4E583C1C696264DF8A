package lk.ijse.recycle.controller;

import javafx.collections.FXCollections;
import javafx.event.ActionEvent;
import javafx.fxml.FXML;
import javafx.fxml.Initializable;
import javafx.scene.control.Alert;
import javafx.scene.control.TableColumn;
import javafx.scene.control.TableView;
import javafx.scene.control.TextField;
import javafx.scene.control.cell.PropertyValueFactory;
import lk.ijse.recycle.dto.PaymentDto;
import lk.ijse.recycle.model.PaymentModel;

import java.net.URL;
import java.sql.SQLException;
import java.util.ResourceBundle;

public class PaymentController implements Initializable {

    @FXML private TextField txtPay_id;
    @FXML private TextField txtOrder_id;
    @FXML private TextField txtPay_value;
    @FXML private TableView<PaymentDto> tblPayment;
    @FXML private TableColumn<PaymentDto, Integer> colPay_id;
    @FXML private TableColumn<PaymentDto, Integer> colOrder_id;
    @FXML private TableColumn<PaymentDto, Double> colPay_value;

    private final String PAYEMENT_ID_REGEX ="^[0-9]+$";
    private final String ORDER_ID_REGEX ="^[0-9]+$";
    private final String PAYEMENT_VALUE_REGEX ="^[0-9]+$";

    private final PaymentModel paymentModel = new PaymentModel();

    @Override
    public void initialize(URL url, ResourceBundle resourceBundle) {
        colPay_id.setCellValueFactory(new PropertyValueFactory<>("payId"));
        colOrder_id.setCellValueFactory(new PropertyValueFactory<>("orderId"));
        colPay_value.setCellValueFactory(new PropertyValueFactory<>("payValue"));
        loadAllPayments();
    }

    private void loadAllPayments() {
        try {
            tblPayment.setItems(FXCollections.observableArrayList(paymentModel.getAllPayements()));
        } catch (SQLException e) {
            e.printStackTrace();
        }
    }

    @FXML
    void btnSaveOnAction(ActionEvent event) {
        try {
            PaymentDto dto = new PaymentDto(
                    Integer.parseInt(txtPay_id.getText()),
                    Integer.parseInt(txtOrder_id.getText()),
                    Double.parseDouble(txtPay_value.getText())
            );
            if (paymentModel.savePayement(dto)) {
                new Alert(Alert.AlertType.INFORMATION, "Payment Saved!").show();
                loadAllPayments();
                clearFields();
            }
        } catch (Exception e) {
            e.printStackTrace();
        }
    }

    @FXML
    void btnUpdateOnAction(ActionEvent event) {
        try {
            PaymentDto dto = new PaymentDto(
                    Integer.parseInt(txtPay_id.getText()),
                    Integer.parseInt(txtOrder_id.getText()),
                    Double.parseDouble(txtPay_value.getText())
            );
            if (paymentModel.updatePayement(dto)) {
                new Alert(Alert.AlertType.INFORMATION, "Payment Updated!").show();
                loadAllPayments();
                clearFields();
            }
        } catch (Exception e) {
            e.printStackTrace();
        }
    }

    @FXML
    void btnDeleteOnAction(ActionEvent event) {

        if(txtPay_id.getText().isEmpty()) {
            new Alert(Alert.AlertType.WARNING, "Payment enter Pay_id Delete").show();
            return;
        }
        try {
            int orderId = Integer.parseInt(txtOrder_id.getText());
            if (paymentModel.deletePayement(orderId)) {
                new Alert(Alert.AlertType.INFORMATION, "Payment Deleted!").show();
                loadAllPayments();
                clearFields();

            }else{
                new Alert(Alert.AlertType.ERROR, "Delete faild").show();
            }
        } catch (Exception e) {
            e.printStackTrace();
        }
    }

    @FXML
    void btnResetOnAction(ActionEvent event) {
        clearFields();
    }

    private void clearFields() {
        txtPay_id.clear();
        txtOrder_id.clear();
        txtPay_value.clear();
    }

    public void btnPayementId(ActionEvent actionEvent) {
        btnSaveOnAction(actionEvent);
    }

    public void btnOrderId(ActionEvent actionEvent) {
        btnUpdateOnAction(actionEvent);
    }

    public void btnPayementValue(ActionEvent actionEvent) {
        btnDeleteOnAction(actionEvent);
    }
}
