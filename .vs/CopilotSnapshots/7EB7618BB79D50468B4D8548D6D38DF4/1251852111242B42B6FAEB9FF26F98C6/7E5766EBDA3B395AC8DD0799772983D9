<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<AnchorPane prefHeight="600.0" prefWidth="800.0" style="-fx-background-color: #013220;" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="lk.ijse.recycle.controller.DeliveryController">
   <children>
      <VBox prefHeight="35.0" prefWidth="800.0">
         <children>
            <Text fill="#f7f3f3" strokeType="OUTSIDE" strokeWidth="0.0" text="                                                           DELIVERY MANAGEMENT" wrappingWidth="763.5918579101562">
               <font>
                  <Font name="System Bold Italic" size="18.0" />
               </font>
            </Text>
         </children>
      </VBox>
      
      <VBox layoutX="15.0" layoutY="50.0" prefHeight="50.0" prefWidth="400.0">
         <children>
            <Text fill="#f7f1f1" strokeType="OUTSIDE" strokeWidth="0.0" text="Delivery ID">
               <font>
                  <Font name="System Bold Italic" size="14.0" />
               </font>
            </Text>
            <TextField fx:id="txtDelivery_Id" editable="false" promptText="Auto Generated" style="-fx-background-radius: 30; -fx-border-radius: 40;" />
         </children>
      </VBox>
      
      <VBox layoutX="15.0" layoutY="105.0" prefHeight="50.0" prefWidth="400.0">
         <children>
            <Text fill="#f7f2f2" strokeType="OUTSIDE" strokeWidth="0.0" text="Order ID">
               <font>
                  <Font name="System Bold Italic" size="14.0" />
               </font>
            </Text>
            <TextField fx:id="txtOrder_Id" promptText="Enter Order ID" style="-fx-background-radius: 30; -fx-border-radius: 40;" />
         </children>
      </VBox>
      
      <VBox layoutX="15.0" layoutY="160.0" prefHeight="50.0" prefWidth="400.0">
         <children>
            <Text fill="#f2eeee" strokeType="OUTSIDE" strokeWidth="0.0" text="Details Location">
               <font>
                  <Font name="System Bold Italic" size="14.0" />
               </font>
            </Text>
            <TextField fx:id="txtDetails_Location" promptText="Enter Delivery Location" style="-fx-background-radius: 30; -fx-border-radius: 40;" />
         </children>
      </VBox>
      
      <!-- Buttons -->
      <Button layoutX="480.0" layoutY="70.0" mnemonicParsing="false" onAction="#btnSaveOnAction" prefHeight="30.0" prefWidth="100.0" style="-fx-background-color: #0E5930;" text="Save" textFill="#f4eded">
         <font>
            <Font name="System Bold" size="12.0" />
         </font>
      </Button>
      <Button layoutX="600.0" layoutY="70.0" mnemonicParsing="false" onAction="#btnUpdateOnAction" prefHeight="30.0" prefWidth="100.0" style="-fx-background-color: #639354;" text="Update" textFill="#f2ecec">
         <font>
            <Font name="System Bold" size="12.0" />
         </font>
      </Button>
      <Button layoutX="480.0" layoutY="120.0" mnemonicParsing="false" onAction="#btnResetOnAction" prefHeight="30.0" prefWidth="100.0" style="-fx-background-color: #356C08;" text="Reset" textFill="#fff9f9">
         <font>
            <Font name="System Bold" size="12.0" />
         </font>
      </Button>
      <Button layoutX="600.0" layoutY="120.0" mnemonicParsing="false" onAction="#btnDeleteOnAction" prefHeight="30.0" prefWidth="100.0" style="-fx-background-color: #7CFC00;" text="Delete">
         <font>
            <Font name="System Bold" size="12.0" />
         </font>
      </Button>
      <Button layoutX="540.0" layoutY="170.0" mnemonicParsing="false" onAction="#btnSearchOnAction" prefHeight="30.0" prefWidth="100.0" style="-fx-background-color: #2E5B0C;" text="Search" textFill="#f4efef">
         <font>
            <Font name="System Bold" size="12.0" />
         </font>
      </Button>
      
      <!-- Table -->
      <TableView fx:id="tblDelivery" layoutX="15.0" layoutY="230.0" prefHeight="350.0" prefWidth="770.0">
        <columns>
          <TableColumn fx:id="colDelivery_Id" prefWidth="250.0" text="Delivery ID" />
          <TableColumn fx:id="colOrder_Id" prefWidth="250.0" text="Order ID" />
          <TableColumn fx:id="colDetails_Location" prefWidth="270.0" text="Details Location" />
        </columns>
      </TableView>
   </children>
</AnchorPane>
