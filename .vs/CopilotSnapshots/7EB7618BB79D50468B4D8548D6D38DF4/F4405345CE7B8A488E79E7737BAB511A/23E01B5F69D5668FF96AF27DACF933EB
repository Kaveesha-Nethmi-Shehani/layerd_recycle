package lk.ijse.recycle.dto;

public class RecycleItemDto {

        private int itemId;
        private String itemMaterials;
        private double itemKg;
        private double itemPrice;
        private String date;

        public RecycleItemDto() {}

        public RecycleItemDto(int itemId, String itemMaterials, double itemKg, double itemPrice, String date) {
            this.itemId = itemId;
            this.itemMaterials = itemMaterials;
            this.itemKg = itemKg;
            this.itemPrice = itemPrice;
            this.date = date;
        }

        public RecycleItemDto(String itemMaterials, double itemKg, double itemPrice) {
            this.itemMaterials = itemMaterials;
            this.itemKg = itemKg;
            this.itemPrice = itemPrice;
        }

        public int getItemId() { return itemId; }
        public void setItemId(int itemId) { this.itemId = itemId; }

        public String getItemMaterials() { return itemMaterials; }
        public void setItemMaterials(String itemMaterials) { this.itemMaterials = itemMaterials; }

        public double getItemKg() { return itemKg; }
        public void setItemKg(double itemKg) { this.itemKg = itemKg; }

        public double getItemPrice() { return itemPrice; }
        public void setItemPrice(double item_price) { this.itemPrice = item_price; }

        public String getDate() { return date; }
        public void setDate(String date) { this.date = date; }
    }


