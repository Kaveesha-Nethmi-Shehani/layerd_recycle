-- Create database
CREATE DATABASE IF NOT EXISTS ecoplayer;
USE ecoplayer;

-- Drop tables if they exist (in correct order to handle foreign keys)
DROP TABLE IF EXISTS delivery;
DROP TABLE IF EXISTS payment;
DROP TABLE IF EXISTS orders;
DROP TABLE IF EXISTS product;
DROP TABLE IF EXISTS recycle_item;
DROP TABLE IF EXISTS customer;

-- Create Customer table
CREATE TABLE customer (
    customer_id INT PRIMARY KEY AUTO_INCREMENT,
    customer_name VARCHAR(100) NOT NULL,
    customer_contact VARCHAR(15) NOT NULL,
    customer_date DATE NOT NULL
);

-- Create Product table
CREATE TABLE product (
    product_id VARCHAR(20) PRIMARY KEY,
    product_name VARCHAR(100) NOT NULL,
    product_materials VARCHAR(255) NOT NULL
);

-- Create RecycleItem table
CREATE TABLE recycle_item (
    item_id INT PRIMARY KEY AUTO_INCREMENT,
    item_materials VARCHAR(100) NOT NULL,
    item_kg DOUBLE NOT NULL,
    item_price DOUBLE NOT NULL,
    date DATE NOT NULL
);

-- Create Orders table (links Customer and Product)
CREATE TABLE orders (
    order_id INT PRIMARY KEY AUTO_INCREMENT,
    bile_id VARCHAR(50) NOT NULL,
    product_name VARCHAR(100) NOT NULL,
    customer_id INT NOT NULL,
    FOREIGN KEY (customer_id) REFERENCES customer(customer_id) ON DELETE CASCADE ON UPDATE CASCADE
);

-- Create Payment table (linked to Order)
CREATE TABLE payment (
    payment_id INT PRIMARY KEY AUTO_INCREMENT,
    order_name VARCHAR(100) NOT NULL,
    order_id INT NOT NULL,
    invoice VARCHAR(100),
    payment_value DOUBLE NOT NULL,
    FOREIGN KEY (order_id) REFERENCES orders(order_id) ON DELETE CASCADE ON UPDATE CASCADE
);

-- Create Delivery table (linked to Order)
CREATE TABLE delivery (
    delivery_id INT PRIMARY KEY AUTO_INCREMENT,
    order_id INT NOT NULL,
    details_location VARCHAR(255) NOT NULL,
    FOREIGN KEY (order_id) REFERENCES orders(order_id) ON DELETE CASCADE ON UPDATE CASCADE
);

