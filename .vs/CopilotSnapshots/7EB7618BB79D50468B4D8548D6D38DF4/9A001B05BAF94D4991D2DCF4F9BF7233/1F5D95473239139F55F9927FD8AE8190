<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<AnchorPane prefHeight="650.0" prefWidth="800.0" style="-fx-background-color: #013220;" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="lk.ijse.recycle.controller.OrderController">
   <children>
      <!-- Title -->
      <Label layoutX="300.0" layoutY="10.0" text="ORDER MANAGEMENT" textFill="white">
         <font><Font name="System Bold Italic" size="20.0" /></font>
      </Label>
      
      <!-- Form Fields - Left Side -->
      <Label layoutX="20.0" layoutY="50.0" text="Order ID" textFill="white">
         <font><Font name="System Bold" size="12.0" /></font>
      </Label>
      <Label fx:id="lblOrder_Id" layoutX="20.0" layoutY="68.0" prefWidth="280.0" prefHeight="25.0" text="N/A" textFill="#7CFC00" style="-fx-background-color: #1a4a1a; -fx-background-radius: 5; -fx-padding: 5;">
         <font><Font name="System Bold" size="14.0" /></font>
      </Label>
      
      <Label layoutX="20.0" layoutY="103.0" text="Select Product" textFill="white">
         <font><Font name="System Bold" size="12.0" /></font>
      </Label>
      <ComboBox fx:id="cmbProduct" layoutX="20.0" layoutY="121.0" prefWidth="280.0" promptText="Select Product" style="-fx-background-radius: 5;" />
      
      <Label layoutX="20.0" layoutY="156.0" text="Stock Available" textFill="white">
         <font><Font name="System Bold" size="12.0" /></font>
      </Label>
      <Label fx:id="lblStock_Available" layoutX="20.0" layoutY="174.0" prefWidth="130.0" prefHeight="25.0" text="0" textFill="#FFD700" style="-fx-background-color: #1a4a1a; -fx-background-radius: 5; -fx-padding: 5;">
         <font><Font name="System Bold" size="12.0" /></font>
      </Label>
      
      <Label layoutX="160.0" layoutY="156.0" text="Unit Price" textFill="white">
         <font><Font name="System Bold" size="12.0" /></font>
      </Label>
      <Label fx:id="lblUnit_Price" layoutX="160.0" layoutY="174.0" prefWidth="140.0" prefHeight="25.0" text="LKR 0.00" textFill="#FFD700" style="-fx-background-color: #1a4a1a; -fx-background-radius: 5; -fx-padding: 5;">
         <font><Font name="System Bold" size="12.0" /></font>
      </Label>
      
      <Label layoutX="20.0" layoutY="209.0" text="Select Customer" textFill="white">
         <font><Font name="System Bold" size="12.0" /></font>
      </Label>
      <ComboBox fx:id="cmbCustomer" layoutX="20.0" layoutY="227.0" prefWidth="280.0" promptText="Select Customer" style="-fx-background-radius: 5;" />
      
      <Label layoutX="20.0" layoutY="262.0" text="Quantity" textFill="white">
         <font><Font name="System Bold" size="12.0" /></font>
      </Label>
      <TextField fx:id="txtQuantity" layoutX="20.0" layoutY="280.0" prefWidth="280.0" promptText="Enter Quantity" style="-fx-background-radius: 5;" />
      
      <Label layoutX="20.0" layoutY="315.0" text="Order Date" textFill="white">
         <font><Font name="System Bold" size="12.0" /></font>
      </Label>
      <DatePicker fx:id="dpOrder_Date" layoutX="20.0" layoutY="333.0" prefWidth="280.0" />
      
      <Label layoutX="20.0" layoutY="368.0" text="Total Price" textFill="white">
         <font><Font name="System Bold" size="14.0" /></font>
      </Label>
      <Label fx:id="lblTotal_Price" layoutX="20.0" layoutY="388.0" prefWidth="280.0" prefHeight="35.0" text="LKR 0.00" textFill="#00FF00" style="-fx-background-color: #1a4a1a; -fx-background-radius: 5; -fx-padding: 5;">
         <font><Font name="System Bold" size="20.0" /></font>
      </Label>
      
      <!-- Buttons - Right Side -->
      <Button layoutX="340.0" layoutY="68.0" mnemonicParsing="false" onAction="#btnSaveOnAction" prefHeight="35.0" prefWidth="120.0" style="-fx-background-color: #0E5930;" text="Place Order" textFill="white">
         <font><Font name="System Bold" size="12.0" /></font>
      </Button>
      <Button layoutX="480.0" layoutY="68.0" mnemonicParsing="false" onAction="#btnUpdateOnAction" prefHeight="35.0" prefWidth="120.0" style="-fx-background-color: #639354;" text="Update" textFill="white">
         <font><Font name="System Bold" size="12.0" /></font>
      </Button>
      <Button layoutX="620.0" layoutY="68.0" mnemonicParsing="false" onAction="#btnDeleteOnAction" prefHeight="35.0" prefWidth="120.0" style="-fx-background-color: #7CFC00;" text="Delete">
         <font><Font name="System Bold" size="12.0" /></font>
      </Button>
      
      <Button layoutX="340.0" layoutY="118.0" mnemonicParsing="false" onAction="#btnResetOnAction" prefHeight="30.0" prefWidth="100.0" style="-fx-background-color: #356C08;" text="Reset" textFill="white">
         <font><Font name="System Bold" size="11.0" /></font>
      </Button>
      <Button layoutX="460.0" layoutY="118.0" mnemonicParsing="false" onAction="#btnReportOnAction" prefHeight="30.0" prefWidth="100.0" style="-fx-background-color: #2E5B0C;" text="Report" textFill="white">
         <font><Font name="System Bold" size="11.0" /></font>
      </Button>
      
      <!-- Info Panel -->
      <Label layoutX="340.0" layoutY="170.0" text="ORDER FLOW:" textFill="#FFD700">
         <font><Font name="System Bold" size="14.0" /></font>
      </Label>
      <Label layoutX="340.0" layoutY="195.0" text="1. Products must be manufactured first" textFill="white">
         <font><Font size="11.0" /></font>
      </Label>
      <Label layoutX="340.0" layoutY="215.0" text="2. Select product with available stock" textFill="white">
         <font><Font size="11.0" /></font>
      </Label>
      <Label layoutX="340.0" layoutY="235.0" text="3. Select customer and enter quantity" textFill="white">
         <font><Font size="11.0" /></font>
      </Label>
      <Label layoutX="340.0" layoutY="255.0" text="4. Total is auto-calculated" textFill="white">
         <font><Font size="11.0" /></font>
      </Label>
      <Label layoutX="340.0" layoutY="275.0" text="5. Stock is reduced when order is placed" textFill="white">
         <font><Font size="11.0" /></font>
      </Label>
      
      <!-- Separator -->
      <Separator layoutX="20.0" layoutY="435.0" prefWidth="760.0" />
      
      <!-- Table -->
      <TableView fx:id="tblOrder" layoutX="20.0" layoutY="445.0" prefHeight="190.0" prefWidth="760.0">
        <columns>
          <TableColumn fx:id="colOrder_Id" prefWidth="80.0" text="Order ID" />
          <TableColumn fx:id="colProduct" prefWidth="150.0" text="Product" />
          <TableColumn fx:id="colCustomer" prefWidth="150.0" text="Customer" />
          <TableColumn fx:id="colQuantity" prefWidth="80.0" text="Qty" />
          <TableColumn fx:id="colTotal_Price" prefWidth="150.0" text="Total (LKR)" />
          <TableColumn fx:id="colOrder_Date" prefWidth="150.0" text="Order Date" />
        </columns>
      </TableView>
   </children>
</AnchorPane>
